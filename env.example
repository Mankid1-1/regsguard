# RegsGuard Environment Variables Template
# Copy this to .env.local for development or set in Vercel for production

# Database
DATABASE_URL="postgresql://username:password@host:port/database"

# Authentication (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# Email Services
RESEND_API_KEY="re_..."
SMTP_HOST="smtp.resend.com"
SMTP_PORT="587"
SMTP_USER="resend"
SMTP_PASS="your_resend_api_key"

# Payment Processing (Stripe)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PRICE_ID="price_..."

# License Verification APIs
MINNESOTA_DLI_API_KEY="mn_dli_api_key"
MINNESOTA_ELECTRICAL_API_KEY="mn_electrical_api_key"
MINNESOTA_PLUMBING_API_KEY="mn_plumbing_api_key"
MINNESOTA_HVAC_API_KEY="mn_hvac_api_key"
WISCONSIN_DSPS_API_KEY="wi_dsps_api_key"
WISCONSIN_ELECTRICAL_API_KEY="wi_electrical_api_key"
WISCONSIN_PLUMBING_API_KEY="wi_plumbing_api_key"
WISCONSIN_HVAC_API_KEY="wi_hvac_api_key"

# Cron Job Security
CRON_SECRET="your_random_secret_key_here"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Performance Optimization
REDIS_URL="redis://username:password@host:port"
CACHE_TTL="300"

# Monitoring (Optional)
SENTRY_DSN="https://your_sentry_dsn"
NEXT_PUBLIC_SENTRY_DSN="https://your_public_sentry_dsn"

# Analytics (Optional)
NEXT_PUBLIC_ANALYTICS_ID="your_analytics_id"
VERCEL_ANALYTICS_ID="your_vercel_analytics_id"

# Development Only
NEXT_PUBLIC_DEV_MODE="true"
ENABLE_DEBUG_LOGS="true"
